# Copy this file to .env and fill in your values. Do not commit .env to version control.
# Alternatively, edit src/constants.py with your credentials.

# OpenAI (required for embeddings and LLM)
OPENAI_API_KEY=your_openai_api_key

# Neo4j (required for the knowledge graph store)
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password
NEO4J_URL=http://localhost:7687

# Google Custom Search API (optional; only for building dataset via search)
GOOGLE_API_KEY=your_google_api_key
SEARCH_ENGINE_ID=your_cx_id
